# ─────────────────────────────────────────────────────────────
# GetAgent — environment template. Copy to `.env` (or `.env.local`) and fill in.
# `.env.local` is loaded first and overrides `.env`.
# ─────────────────────────────────────────────────────────────

# ── Core (required) ──
NODE_ENV=development                       # development | test | production
PORT=8080
OPENROUTER_API_KEY=                        # REQUIRED — the model gateway
MONGODB_URL=mongodb://127.0.0.1:27017/getagent   # required in production (MONGO_URI also accepted)

# ── HTTP hardening ──
# Comma-separated browser origins allowed via CORS. Empty = reflect any origin (dev only).
CORS_ORIGINS=
RATE_LIMIT_WINDOW_MS=60000                 # per-IP limiter window
RATE_LIMIT_MAX=120                         # max requests per window per IP
LOG_LEVEL=info                             # debug | info | warn | error

# ── Access control ──
# Comma-separated UID allowlist (page-level). Empty = allow all (server-side role still enforced).
GETAGENT_UIDS=

# ── Optional integrations (features degrade gracefully if unset) ──
BRAVE_SEARCH_API_KEY=                      # daily-report stock/forex/commodity fallback
NEWS_MARKETS_TOKEN=                        # daily-report news + Twitter feeds
REDDIT_POST_WEBHOOK_URL=                   # POSTed to when /posted marks a Reddit post done

# ── Cloudinary (image generation upload; cleanup on session delete) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Lark / Feishu Bitable (campaigns + announcements data source) ──
LARK_APP_ID=
LARK_APP_SECRET=
LARK_DATA_BASE_APP_TOKEN=
LARK_REWARDS_BASE_APP_TOKEN=
LARK_TABLE_ID_BUILDER_INFO=
LARK_TABLE_ID_CAMPAIGNS=
LARK_TABLE_ID_ACHIEVEMENT=
LARK_TABLE_ID_ANNOUNCEMENTS=
LARK_TABLE_ID_HALL_OF_FAME=
# Dynamic knowledge base: a Bitable table (cols: Slug, Title, Body, Access, Platform,
# Category, Intent, Status). Empty = Lark KB sync disabled; the in-code KB still works.
LARK_TABLE_ID_KNOWLEDGE_BASE=

# Optional live-Lark chat tool via the official lark-cli binary (github.com/larksuite/cli).
# Off by default. The binary must be installed AND authenticated on the host
# (`npx @larksuite/cli@latest install` then `lark-cli auth login`) — it stores
# credentials in the OS keychain, so this suits a persistent host, not an ephemeral container.
LARK_CLI_ENABLED=false
LARK_CLI_BIN=lark-cli

# General Lark agent (POST /server/agent/lark, leaders-only) via the official
# @larksuiteoapi/lark-mcp server. Off by default. Uses LARK_APP_ID/SECRET above.
# Writes (meetings/messages/records) go through preview-and-confirm.
LARK_MCP_ENABLED=false
LARK_MCP_DOMAIN=https://open.larksuite.com
LARK_MCP_TOOLS=preset.calendar.default,preset.im.default,preset.base.default
LARK_MCP_TOKEN_MODE=tenant_access_token   # auto | tenant_access_token | user_access_token

# ── Web client (web/) ──
# NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
