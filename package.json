{
  "name": "getagent-langchain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GetAgent rebuild — LangChain.js (OpenRouter gateway) + Express + MongoDB. See ../Bitget-Builder-Hub/server/getagent-langchain-rebuild.md",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node scripts/build.mjs",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,css,html}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "@langchain/core": "^0.3.40",
    "@langchain/mcp-adapters": "^0.6.0",
    "@langchain/openai": "^0.4.4",
    "@larksuiteoapi/lark-mcp": "^0.5.1",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "gray-matter": "^4.0.3",
    "mammoth": "^1.9.0",
    "mongoose": "^8.9.5",
    "node-cron": "^3.0.3",
    "pdf-parse": "^1.1.1",
    "xlsx": "^0.18.5",
    "yahoo-finance2": "^3.15.3",
    "zod": "^3.24.1"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "1.12.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "esbuild": "^0.28.1",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.12.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.8"
  }
}
